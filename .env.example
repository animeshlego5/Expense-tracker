# Required in production. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The app's public URL (http://localhost:3000 in dev)
BETTER_AUTH_URL=http://localhost:3000

# Neon Postgres POOLED connection string (host contains "-pooler").
# Leave unset in local dev to use the embedded PGlite database (./.pglite).
# DATABASE_URL=

# Neon DIRECT connection string — used only by drizzle-kit for migrations.
# DIRECT_DATABASE_URL=
